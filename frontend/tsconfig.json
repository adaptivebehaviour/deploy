{
    "compilerOptions": {
        "target": "ES2017",
        "lib": [
            "dom",
            "dom.iterable",
            "esnext"
        ],
        "allowJs": true,
        "skipLibCheck": true,
        "strict": true,
        "noEmit": true,
        "esModuleInterop": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "react-jsx",
        "incremental": true,
        "strictNullChecks": true,
        "plugins": [
            {
                "name": "next"
            }
        ],
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./*"
            ],
            "@/manifesto/*": [
                "./src/manifesto/*"
            ],
            "@/logging": [
                "./src/manifesto/logging"
            ],
            "@/collection/*": [
                "./src/manifesto/server_child4/*"
            ],
            "@/server_child4/*": [
                "./src/manifesto/server_child4/*"
            ],
            "@/nextjs/*": [
                "./src/manifesto/nextjs/*"
            ],
            "@/web/*": [
                "./src/manifesto/web/*"
            ],
            "@/frontend/*": [
                "./src/manifesto/frontend/*"
            ]
        }
    },
    "include": [
        "next-env.d.ts",
        "**/*.ts",
        "**/*.tsx",
        ".next/types/**/*.ts",
        "next.config.js",
        ".next/dev/types/**/*.ts",
        "**/*.mts"
    ],
    "exclude": [
        "node_modules"
    ]
}