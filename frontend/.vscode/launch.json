{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch",
            "type": "chrome",
            "request": "launch",
            "preLaunchTask": "launch",
            "postDebugTask": "stop",
            "url": "http://localhost:3000",
            "webRoot": "${workspaceFolder}",
            "resolveSourceMapLocations": [
                "${workspaceFolder}/",
                "!/node_modules/**"
            ]
        },
        {
            "name": "Dev",
            "type": "chrome",
            "request": "launch",
            "preLaunchTask": "launch",
            "postDebugTask": "stop",
            "url": "http://localhost:3000/dev",
            "webRoot": "${workspaceFolder}",
            "resolveSourceMapLocations": [
                "${workspaceFolder}/",
                "!/node_modules/**"
            ]
        },
        {
            "name": "Tests",
            "type": "chrome",
            "request": "launch",
            "preLaunchTask": "launch",
            "postDebugTask": "stop",
            "url": "http://localhost:3000/tests",
            "webRoot": "${workspaceFolder}",
            "resolveSourceMapLocations": [
                "${workspaceFolder}/",
                "!/node_modules/**"
            ]
        }
    ]
}